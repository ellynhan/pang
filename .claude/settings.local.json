{
  "permissions": {
    "allow": [
      "PowerShell(Get-ChildItem -Path \"C:\\\\reviewer\\\\pang\" -Force | Where-Object { $_.Name -ne 'node_modules' })",
      "PowerShell(Get-ChildItem -Path \"C:\\\\reviewer\\\\pang\" -Force | Select-Object Name, @{Name=\"Type\";Expression={if\\($_.PSIsContainer\\){\"Directory\"}else{\"File\"}}} | Format-Table -AutoSize)",
      "PowerShell(Get-ChildItem -Path \"C:\\\\reviewer\\\\pang\" -Recurse -Exclude \"node_modules\" -Force | Where-Object { $_.PSIsContainer -eq $false } | ForEach-Object { $_.FullName -replace [regex]::Escape\\(\"C:\\\\reviewer\\\\pang\\\\\"\\), \"\" } | Sort-Object)",
      "PowerShell(Get-ChildItem -Path \"C:\\\\reviewer\\\\pang\" -Exclude \"node_modules\" -Recurse -Force | Where-Object { -not $_.PSIsContainer } | Select-Object @{Name=\"RelativePath\";Expression={$_.FullName -replace [regex]::Escape\\(\"C:\\\\reviewer\\\\pang\\\\\"\\), \"\"}} | Where-Object { $_.RelativePath -notmatch \"node_modules\" })",
      "Bash(git init *)",
      "Bash(git add *)"
    ]
  }
